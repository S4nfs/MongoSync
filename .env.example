# ==============================================================================
# MongoSync Configuration Template
# Duplicate this file as '.env' and fill in your credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. LOCAL REPLICA SET CREDENTIALS
# These variables define the root user and password that will be created on the
# local MongoDB instances (mongo1, mongo2, mongo3) when they initialize for the first time.
# ------------------------------------------------------------------------------
MONGO_USER=your_local_root_username
MONGO_PASS=your_local_root_password

# ------------------------------------------------------------------------------
# 2. TARGET DATABASE NAME FOR REAL-TIME SYNC
# The specific database that the background real-time sync service (sync.js)
# should monitor for change streams and replicate locally.
# (Note: The initial-sync utility script is interactive and allows selecting any DBs/collections).
# ------------------------------------------------------------------------------
DB_NAME=test

# ------------------------------------------------------------------------------
# 3. MONGODB ATLAS CONNECTION URI (Source Database)
# Secure URI for connecting to MongoDB Atlas.
# NOTE: Special characters in your password (like '@', ':', '/') MUST be URL-encoded.
# If your password has a '+', replace it with '%2B'.
# ------------------------------------------------------------------------------
ATLAS_URI=mongodb+srv://atlas_user:atlas_password%2B@cluster0.yourcluster.mongodb.net

# ------------------------------------------------------------------------------
# 4. LOCAL REPLICA SET CONNECTION URI (Target Database)
# This URI is used by the sync service to connect to the local 3-node replica set.
# NOTE: 
# - Ensure hostnames match the service names ('mongo1', 'mongo2', 'mongo3') in docker-compose.
# - Credentials must match MONGO_USER and MONGO_PASS exactly.
# - Ensure your password is URL-encoded here as well.
# - Use 'authSource=admin' because root credentials reside in the admin database.
# ------------------------------------------------------------------------------
LOCAL_URI=mongodb://your_local_root_username:your_local_root_password%2B@mongo1:27017,mongo2:27017,mongo3:27017/?replicaSet=rs0&authSource=admin
